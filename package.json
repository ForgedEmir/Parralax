{
  "name": "parallax-reality-reconciliation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.app.json && vite build",
    "start": "tsx server/index.ts --static",
    "mcp": "tsx server/mcp.ts",
    "demo:hermes": "node scripts/hermes-demo.mjs",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "smoke:vision": "node scripts/live-vision-smoke.mjs",
    "verify": "pnpm test && pnpm build && pnpm smoke:mcp && pnpm smoke:vision",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "express": "^4.21.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0"
}
